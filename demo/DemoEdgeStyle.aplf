 'F1.H_B0'    eWC'Label' 'Border=0' (65 640)(20 80)('FCol'(120 0 0))
 'F1.H_B1'    eWC'Label' 'Border=1' (65 730)(20 80)('FCol'(120 0 0))
 'F1.H_B1R'   eWC'Label' 'B=1+Ridge'(65 820)(20 80)('FCol'(120 80 0))
