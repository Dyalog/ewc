 'F1.SF_Shadow.lbl'eWC'Label' 'Shadow'(5 5)(20 70)

 'F1.SF_None'    eWC'SubForm'('Posn'(370 550))('Size'(80 80))('EdgeStyle' 'None')    ('BCol'(245 245 255))
 'F1.SF_None.lbl'eWC'Label' 'None'  (5 5)(20 70)

 'F1.SF_B0'      eWC'SubForm'('Posn'(370 640))('Size'(80 80))('Border' 0)            ('BCol'(245 245 255))
 'F1.SF_B0.lbl'  eWC'Label' 'B=0'   (5 5)(20 70)

 'F1.SF_B1'      eWC'SubForm'('Posn'(370 730))('Size'(80 80))('Border' 1)            ('BCol'(245 245 255))
 'F1.SF_B1.lbl'  eWC'Label' 'B=1'   (5 5)(20 70)

 'F1.SF_B1Ridge' eWC'SubForm'('Posn'(370 820))('Size'(80 80))('Border' 1)('EdgeStyle' 'Ridge')('BCol'(245 245 255))
 'F1.SF_B1Ridge.lbl'eWC'Label' 'B1+Ridge'(5 5)(20 70)

 'F1.SF_B1None'  eWC'SubForm'('Posn'(370 910))('Size'(80 80))('Border' 1)('EdgeStyle' 'None')('BCol'(245 245 255))
 'F1.SF_B1None.lbl'eWC'Label' 'B1+None'(5 5)(20 70)

 'F1.SF_Default'   eWC'SubForm'('Posn'(370 1000))('Size'(80 80))('EdgeStyle' 'Default')('BCol'(245 245 255))
 'F1.SF_Default.lbl'eWC'Label' 'Default'(5 5)(20 70)

 'F1.SF_B1Default' eWC'SubForm'('Posn'(370 1090))('Size'(80 80))('Border' 1)('EdgeStyle' 'Default')('BCol'(245 245 255))
 'F1.SF_B1Default.lbl'eWC'Label' 'B1+Def'(5 5)(20 70)

⍝ ─── Notes ─────────────────────────────────────────────────────────
 'F1.NOTE1'eWC'Label' 'EdgeStyle wins on appearance: B=1+Ridge always shows a Ridge border, regardless of Border value.'(470 10)(20 980)('FCol'(80 80 80))
 'F1.NOTE2'eWC'Label' 'EdgeStyle="None" is treated as no EdgeStyle, so Border alone decides: B=1+None draws a plain frame, B=0+None draws nothing.'(495 10)(20 980)('FCol'(80 80 80))
 'F1.NOTE3'eWC'Label' 'B=0 + no EdgeStyle: no border drawn (default state for Edit/Label/SubForm).'(520 10)(20 980)('FCol'(80 80 80))
 'F1.NOTE4'eWC'Label' 'EdgeStyle="Default" (and any unrecognised value) is treated as no 3-D edge: Border alone decides, so B=1+Default draws a plain frame.'(545 10)(20 1180)('FCol'(80 80 80))
