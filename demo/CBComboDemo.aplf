 CBComboDemo args;id;event;info;text;msg
 id event info text‚Üê4‚Üëargs

 :Select id
 :Case 'F1.Colour'
     'F1.ColourResult'eWS'Caption' text
     msg‚Üê'Colour selected: ',text

 :Case 'F1.SizeCombo'
     EWC.COMBO_COUNT+‚Üê1
     'F1.SizeCount'eWS'Caption'(‚çïEWC.COMBO_COUNT)
     'F1.SizeResult'eWS'Caption' text
     msg‚Üê'Size #',(‚çïEWC.COMBO_COUNT),': ',text,' (even reselects fire!)'

 :Case 'F1.StyledCombo1'
     msg‚Üê'Fruit: ',text

 :Case 'F1.StyledCombo2'
     msg‚Üê'Status: ',text

 :Else
     msg‚Üêid,' Select: ',text
 :EndSelect

 ‚çù Append to event log
 ‚éï‚Üêmsg
 AppendComboLog msg
