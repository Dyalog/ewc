 CBGridCombo args;id;event;row;col;val;msg
 id event‚Üê2‚Üëargs

 :Select event
 :Case 'CellChanged'
     row col val‚Üê3‚Üë2‚Üìargs
     msg‚Üê'Grid CellChanged: Row ',(‚çïrow),' Col ',(‚çïcol),' = "',val,'"'
     'F1.GridLog'eWS'Caption' msg

 :Case 'Select'
     row col‚Üê2‚Üë2‚Üìargs
     msg‚Üê'Grid Select: Row ',(‚çïrow),' Col ',(‚çïcol)
     'F1.GridLog'eWS'Caption' msg
 :EndSelect

 AppendComboLog msg
